APP_ENV=dev
LOG_LEVEL=DEBUG
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Internal API Key (Django ↔ FastAPI 공유 시크릿, 헤더 X-Internal-Api-Key)
INTERNAL_API_KEY=your_internal_api_key_here

# LLM
EMBEDDING_MODEL=nlpai-lab/KURE-v1
LLM_API_KEY=
LLM_MODEL=LGAI-EXAONE/EXAONE-3.5-7.8B-Instruct
LLM_BASE_URL=

# Qdrant
QDRANT_PATH=./vector_db
QDRANT_URL=qdrant_url_here
QDRANT_API_KEY=your_qdrant_api_key_here
COLLECTION_LEGAL=legal
COLLECTION_CONTRACTS=contracts

# Search Parameteres
RETRIEVAL_TOP_K=5
CONTEXT_TOP_K=3
RELEVANCE_THRESHOLD=0.35

# PDF / OCR 한도 (Django 통합 OCR 엔드포인트용)
MAX_PDF_BYTES=5242880
MAX_PDF_PAGES=50
OCR_TIMEOUT_SECONDS=60

OC=oc_value_here